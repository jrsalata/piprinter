[Unit]
Description=Piprinter webserver
After=network.target

[Service]
Type=simple
User=username
Group=username
WorkingDirectory=/home/username/piprinter/
ExecStart=/home/username/piprinter/.venv/bin/python -u main.py
Restart=always
RestartSec=5
Environment="PIPRINTER_CONFIG_PATH=/path/to/printer"
Environment="PIPRINTER_LISTEN_IP=localhost"
Environment="PIPRINTER_PORT=8080"

[Install]
WantedBy=multi-user.target